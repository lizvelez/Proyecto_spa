using System;
using System.Collections.Generic;

namespace SpaApp
{
    class Program
    {
        static List<Cita> citas = new List<Cita>();

        static void Main(string[] args)
        {
            int opcion;

            do
            {
                Console.Clear();
                Console.WriteLine("===== SISTEMA SPA =====");
                Console.WriteLine("1. Registrar cita");
                Console.WriteLine("2. Ver citas");
                Console.WriteLine("3. Cancelar cita");
                Console.WriteLine("4. Salir");
                Console.Write("Seleccione una opción: ");
                opcion = int.Parse(Console.ReadLine());

                switch (opcion)
                {
                    case 1:
                        RegistrarCita();
                        break;
                    case 2:
                        MostrarCitas();
                        break;
                    case 3:
                        CancelarCita();
                        break;
                }

                Console.WriteLine("\nPresione una tecla para continuar...");
                Console.ReadKey();

            } while (opcion != 4);
        }

        static void RegistrarCita()
        {
            Console.Clear();
            Cita nueva = new Cita();

            Console.Write("Nombre del cliente: ");
            nueva.NombreCliente = Console.ReadLine();

            Console.Write("Servicio (Masaje / Facial / Manicure): ");
            nueva.Servicio = Console.ReadLine();

            Console.Write("Fecha (dd/mm/aaaa): ");
            nueva.Fecha = Console.ReadLine();

            Console.Write("Hora (ej: 10:00 AM): ");
            nueva.Hora = Console.ReadLine();

          
            foreach (var c in citas)
            {
                if (c.Fecha == nueva.Fecha && c.Hora == nueva.Hora)
                {
                    Console.WriteLine("\n Ese horario ya está ocupado.");
                    return;
                }
            }

            citas.Add(nueva);
            Console.WriteLine("\n Cita registrada con éxito.");
        }

        static void MostrarCitas()
        {
            Console.Clear();

            if (citas.Count == 0)
            {
                Console.WriteLine("No hay citas registradas.");
                return;
            }

            Console.WriteLine("===== LISTA DE CITAS =====");

            int i = 1;
            foreach (var c in citas)
            {
                Console.WriteLine($"Cita #{i}");
                Console.WriteLine($"Cliente: {c.NombreCliente}");
                Console.WriteLine($"Servicio: {c.Servicio}");
                Console.WriteLine($"Fecha: {c.Fecha}");
                Console.WriteLine($"Hora: {c.Hora}");
                Console.WriteLine("----------------------------");
                i++;
            }
        }

        static void CancelarCita()
        {
            Console.Clear();

            if (citas.Count == 0)
            {
                Console.WriteLine("No hay citas para cancelar.");
                return;
            }

            MostrarCitas();
            Console.Write("\nIngrese el número de la cita a cancelar: ");
            int numero = int.Parse(Console.ReadLine());

            if (numero > 0 && numero <= citas.Count)
            {
                citas.RemoveAt(numero - 1);
                Console.WriteLine("Cita cancelada correctamente.");
            }
            else
            {
                Console.WriteLine("Número inválido.");
            }
        }
    }

    class Cita
    {
        public string NombreCliente { get; set; }
        public string Servicio { get; set; }
        public string Fecha { get; set; }
        public string Hora { get; set; }
    }
}
